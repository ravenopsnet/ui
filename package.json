{
  "name": "@ravenopsnet/ui",
  "version": "0.0.14",
  "description": "Tree-shakeable React 19 component library built from the shadcn/ui component set.",
  "keywords": [
    "react",
    "components",
    "design-system",
    "shadcn",
    "tailwindcss",
    "ui"
  ],
  "author": "RavenOps Network",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ravenopsnet/ui.git"
  },
  "homepage": "https://github.com/ravenopsnet/ui#readme",
  "bugs": {
    "url": "https://github.com/ravenopsnet/ui/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.2.2",
  "type": "module",
  "private": false,
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./components/*": {
      "types": "./dist/components/ui/*.d.ts",
      "import": "./dist/components/ui/*.js",
      "default": "./dist/components/ui/*.js"
    },
    "./styles.css": "./dist/styles.css",
    "./style.css": "./dist/styles.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "tsc -b && vite build && node scripts/verify-package.mjs",
    "typecheck": "tsc -b",
    "ci": "npm run lint && npm run format:check && npm test",
    "prepack": "npm run build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/inter": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.17.0",
    "next-themes": "^0.4.6",
    "react-day-picker": "^10.0.1",
    "react-resizable-panels": "^4.11.2",
    "recharts": "3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10",
    "@tailwindcss/vite": "^4",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "eslint": "^10",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6",
    "typescript-eslint": "^8",
    "vite": "^8",
    "vite-plugin-dts": "^5.0.2"
  }
}
